{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-shipping" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-shipping" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><a href="#tab-settings" data-bs-toggle="tab" class="nav-link active">{{ tab_settings }}</a></li>
            <li class="nav-item"><a href="#tab-origins"  data-bs-toggle="tab" class="nav-link">{{ tab_origins }}</a></li>
            <li class="nav-item"><a href="#tab-carriers" data-bs-toggle="tab" class="nav-link">{{ tab_carriers }}</a></li>
            <li class="nav-item"><a href="#tab-logs"     data-bs-toggle="tab" class="nav-link">{{ tab_logs }}</a></li>
            <li class="nav-item ms-auto"><a href="#tab-docs" data-bs-toggle="tab" class="nav-link"><i class="fa-solid fa-circle-question"></i> {{ tab_docs }}</a></li>
          </ul>
          <div class="tab-content">
            <div id="tab-settings" class="tab-pane active">
              <div class="row mb-3">
                <label for="input-environment" class="col-sm-3 col-form-label">{{ entry_environment }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_environment" id="input-environment" class="form-select">
                    <option value="sandbox"   {% if shipping_enviatodo_environment == 'sandbox'    %} selected{% endif %}>{{ text_environment_sandbox }}</option>
                    <option value="production"{% if shipping_enviatodo_environment == 'production' %} selected{% endif %}>{{ text_environment_production }}</option>
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-token-sandbox" class="col-sm-3 col-form-label">{{ entry_token_sandbox }}</label>
                <div class="col-sm-9">
                  <input type="text" name="shipping_enviatodo_token_sandbox" value="{{ shipping_enviatodo_token_sandbox }}" placeholder="{{ entry_token_sandbox }}" id="input-token-sandbox" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-token-production" class="col-sm-3 col-form-label">{{ entry_token_production }}</label>
                <div class="col-sm-9">
                  <input type="text" name="shipping_enviatodo_token_production" value="{{ shipping_enviatodo_token_production }}" placeholder="{{ entry_token_production }}" id="input-token-production" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-client-id" class="col-sm-3 col-form-label">{{ entry_client_id }}</label>
                <div class="col-sm-9">
                  <input type="text" name="shipping_enviatodo_client_id" value="{{ shipping_enviatodo_client_id }}" placeholder="88950" id="input-client-id" class="form-control"/>
                  <small class="form-text text-muted">{{ help_client_id }}</small>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-base-url-override" class="col-sm-3 col-form-label">{{ entry_base_url_override }}</label>
                <div class="col-sm-9">
                  <input type="text" name="shipping_enviatodo_base_url_override" value="{{ shipping_enviatodo_base_url_override }}" placeholder="https://apiqav3.enviatodo.com/index.php" id="input-base-url-override" class="form-control"/>
                  <small class="form-text text-muted">{{ help_base_url_override|raw }}</small>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-default-origin" class="col-sm-3 col-form-label">{{ entry_default_origin }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_default_origin_id" id="input-default-origin" class="form-select">
                    <option value="0">{{ text_select_origin }}</option>
                    {% for origin in origins %}
                      <option value="{{ origin.origin_id }}"{% if origin.origin_id == shipping_enviatodo_default_origin_id %} selected{% endif %}>{{ origin.name }}{% if origin.is_default %} ★{% endif %}</option>
                    {% endfor %}
                  </select>
                  {% if origins|length == 0 %}<small class="form-text text-muted">{{ help_origins_empty }}</small>{% endif %}
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-package-strategy" class="col-sm-3 col-form-label">{{ entry_package_strategy }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_package_strategy" id="input-package-strategy" class="form-select">
                    <option value="aggregate"{% if shipping_enviatodo_package_strategy == 'aggregate' %} selected{% endif %}>{{ text_strategy_aggregate }}</option>
                    <option value="per_item" {% if shipping_enviatodo_package_strategy == 'per_item'  %} selected{% endif %}>{{ text_strategy_per_item }}</option>
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-tax-class" class="col-sm-3 col-form-label">{{ entry_tax_class }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_tax_class_id" id="input-tax-class" class="form-select">
                    <option value="0">{{ text_none }}</option>
                    {% for tax_class in tax_classes %}
                      <option value="{{ tax_class.tax_class_id }}"{% if tax_class.tax_class_id == shipping_enviatodo_tax_class_id %} selected{% endif %}>{{ tax_class.title }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-geo-zone" class="col-sm-3 col-form-label">{{ entry_geo_zone }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_geo_zone_id" id="input-geo-zone" class="form-select">
                    <option value="0">{{ text_all_zones }}</option>
                    {% for geo_zone in geo_zones %}
                      <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == shipping_enviatodo_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="shipping_enviatodo_status" value="0"/>
                    <input type="checkbox" name="shipping_enviatodo_status" value="1" id="input-status" class="form-check-input"{% if shipping_enviatodo_status %} checked{% endif %}/>
                  </div>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-sort-order" class="col-sm-3 col-form-label">{{ entry_sort_order }}</label>
                <div class="col-sm-9">
                  <input type="text" name="shipping_enviatodo_sort_order" value="{{ shipping_enviatodo_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-log-level" class="col-sm-3 col-form-label">{{ entry_log_level }}</label>
                <div class="col-sm-9">
                  <select name="shipping_enviatodo_log_level" id="input-log-level" class="form-select">
                    <option value="off"  {% if shipping_enviatodo_log_level == 'off'   %} selected{% endif %}>{{ text_log_off }}</option>
                    <option value="error"{% if shipping_enviatodo_log_level == 'error' %} selected{% endif %}>{{ text_log_error }}</option>
                    <option value="info" {% if shipping_enviatodo_log_level == 'info'  %} selected{% endif %}>{{ text_log_info }}</option>
                    <option value="debug"{% if shipping_enviatodo_log_level == 'debug' %} selected{% endif %}>{{ text_log_debug }}</option>
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_test_connection }}</label>
                <div class="col-sm-9">
                  <button type="button" id="button-test-connection" class="btn btn-secondary"><i class="fa-solid fa-plug"></i> {{ button_test_connection }}</button>
                  <div id="test-connection-result" class="mt-2"></div>
                </div>
              </div>
            </div>
            <div id="tab-origins" class="tab-pane">
              <div class="d-flex justify-content-end mb-2">
                <button type="button" class="btn btn-primary btn-sm" id="button-add-origin"><i class="fa-solid fa-plus"></i> {{ button_add_origin }}</button>
              </div>
              <div id="origins-table-wrapper">
                {% include 'extension/enviatodo/admin/view/template/shipping/_origins_table.twig' %}
              </div>
            </div>
            <div id="tab-carriers" class="tab-pane">
              <div class="d-flex justify-content-end mb-2">
                <button type="button" class="btn btn-secondary btn-sm" id="button-refresh-carriers"><i class="fa-solid fa-rotate"></i> {{ button_refresh_carriers }}</button>
              </div>
              <div id="carriers-table-wrapper">
                {% include 'extension/enviatodo/admin/view/template/shipping/_carriers_table.twig' %}
              </div>
            </div>
            <div id="tab-logs" class="tab-pane">
              {% include 'extension/enviatodo/admin/view/template/shipping/_logs_table.twig' %}
            </div>
            <div id="tab-docs" class="tab-pane">
              {% include 'extension/enviatodo/admin/view/template/shipping/_docs.twig' %}
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modal-origin" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form id="form-origin">
        <div class="modal-header">
          <h5 class="modal-title" id="modal-origin-title">{{ button_add_origin }}</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="origin-error" class="alert alert-danger d-none"></div>
          <input type="hidden" name="origin_id" value="0" />
          {% if address_sources %}
          <div class="row mb-3">
            <div class="col-md-12">
              <label class="form-label" for="origin-prefill-source">{{ entry_origin_prefill }}</label>
              <select id="origin-prefill-source" class="form-select">
                <option value="">{{ text_origin_prefill_choose }}</option>
                {% for src in address_sources %}
                  <option value="{{ src.id }}">{{ src.label }}</option>
                {% endfor %}
              </select>
              <small class="text-muted">{{ help_origin_prefill }}</small>
            </div>
          </div>
          {% endif %}
          <div class="row">
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_name }} *</label><input type="text" name="name" class="form-control" required /></div>
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_contact }}</label><input type="text" name="contact" class="form-control" /></div>
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_phone }}</label><input type="text" name="phone" class="form-control" /></div>
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_email }}</label><input type="email" name="email" class="form-control" /></div>
            <div class="col-md-8 mb-2"><label class="form-label">{{ entry_origin_street }}</label><input type="text" name="street" class="form-control" /></div>
            <div class="col-md-4 mb-2"><label class="form-label">{{ entry_origin_number }}</label><input type="text" name="number" class="form-control" /></div>
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_district }}</label><input type="text" name="district" class="form-control" /></div>
            <div class="col-md-6 mb-2"><label class="form-label">{{ entry_origin_city }}</label><input type="text" name="city" class="form-control" /></div>
            <div class="col-md-4 mb-2"><label class="form-label">{{ entry_origin_state }}</label><input type="text" name="state" class="form-control" /></div>
            <div class="col-md-4 mb-2"><label class="form-label">{{ entry_origin_postal_code }} *</label><input type="text" name="postal_code" class="form-control" required /></div>
            <div class="col-md-4 mb-2"><label class="form-label">{{ entry_origin_country }} *</label><input type="text" name="country" class="form-control" maxlength="2" value="MX" required /></div>
            <div class="col-md-12 mb-2"><div class="form-check"><input type="checkbox" class="form-check-input" name="is_default" value="1" id="origin-is-default"><label class="form-check-label" for="origin-is-default">{{ entry_origin_is_default }}</label></div></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ button_cancel }}</button>
          <button type="submit" class="btn btn-primary">{{ button_save }}</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script type="text/javascript">
document.getElementById('button-test-connection').addEventListener('click', function () {
  var btn  = this;
  var box  = document.getElementById('test-connection-result');
  var form = document.getElementById('form-shipping');
  var fd   = new FormData(form);

  btn.disabled = true;
  box.innerHTML = '<span class="text-muted"><i class="fa-solid fa-spinner fa-spin"></i> {{ text_testing }}</span>';

  fetch('{{ test_connection }}', { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin' })
    .then(function (r) {
      return r.text().then(function (txt) {
        try { return JSON.parse(txt); }
        catch (e) { throw new Error('Non-JSON response (HTTP ' + r.status + '): ' + txt.substring(0, 200)); }
      });
    })
    .then(function (json) {
      if (json.error) {
        box.innerHTML = '<div class="alert alert-danger mb-0">' + json.error + '</div>';
      } else {
        box.innerHTML = '<div class="alert alert-success mb-0">' + json.success + ' <small class="text-muted">(' + (json.base_url || '') + ')</small></div>';
      }
    })
    .catch(function (e) { box.innerHTML = '<div class="alert alert-danger mb-0">' + e.message + '</div>'; })
    .finally(function () { btn.disabled = false; });
});

(function () {
  var modalEl   = document.getElementById('modal-origin');
  var $modal    = window.jQuery ? window.jQuery(modalEl) : null;
  var form      = document.getElementById('form-origin');
  var titleEl   = document.getElementById('modal-origin-title');
  var errorBox  = document.getElementById('origin-error');
  var wrapper   = document.getElementById('origins-table-wrapper');
  var prefillEl = document.getElementById('origin-prefill-source');
  var prefillMap = {
    {% for src in address_sources %}
      "{{ src.id }}": {{ src.prefill|json_encode|raw }}{% if not loop.last %},{% endif %}
    {% endfor %}
  };

  function showModal()  { if ($modal) { $modal.modal('show'); } else { modalEl.style.display = 'block'; modalEl.classList.add('show'); } }
  function hideModal()  { if ($modal) { $modal.modal('hide'); } else { modalEl.style.display = 'none'; modalEl.classList.remove('show'); } }

  function resetForm() {
    form.reset();
    form.elements['origin_id'].value = '0';
    form.elements['country'].value = 'MX';
    if (prefillEl) prefillEl.value = '';
    errorBox.classList.add('d-none');
    errorBox.textContent = '';
    titleEl.textContent = '{{ button_add_origin }}';
  }

  if (prefillEl) {
    prefillEl.addEventListener('change', function () {
      var data = prefillMap[prefillEl.value];
      if (!data) return;
      Object.keys(data).forEach(function (k) {
        if (form.elements[k] && data[k] !== '' && data[k] !== null && data[k] !== undefined) {
          form.elements[k].value = data[k];
        }
      });
    });
  }

  function bindRowActions() {
    wrapper.querySelectorAll('.origin-edit').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-origin-id');
        fetch('{{ origin_get }}&origin_id=' + encodeURIComponent(id), { credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
          .then(function (r) { return r.json(); })
          .then(function (json) {
            if (json.error) { alert(json.error); return; }
            resetForm();
            titleEl.textContent = '{{ button_edit }}';
            var o = json.origin;
            ['origin_id','name','contact','phone','email','street','number','district','city','state','postal_code','country'].forEach(function (k) {
              if (form.elements[k]) form.elements[k].value = o[k] || '';
            });
            form.elements['is_default'].checked = !!parseInt(o.is_default || 0);
            showModal();
          });
      });
    });

    wrapper.querySelectorAll('.origin-delete').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!confirm('{{ text_confirm_delete }}')) return;
        var fd = new FormData();
        fd.append('origin_id', btn.getAttribute('data-origin-id'));
        fetch('{{ origin_delete }}', { method: 'POST', body: fd, credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
          .then(function (r) { return r.json(); })
          .then(function (json) {
            if (json.error) { alert(json.error); return; }
            window.location.reload();
          });
      });
    });
  }

  document.getElementById('button-add-origin').addEventListener('click', function () {
    resetForm();
    showModal();
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    errorBox.classList.add('d-none');
    var fd = new FormData(form);
    if (!form.elements['is_default'].checked) fd.delete('is_default');
    fetch('{{ origin_save }}', { method: 'POST', body: fd, credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (json.error) {
          errorBox.textContent = json.error;
          errorBox.classList.remove('d-none');
          return;
        }
        hideModal();
        window.location.reload();
      })
      .catch(function (e) {
        errorBox.textContent = e.message;
        errorBox.classList.remove('d-none');
      });
  });

  bindRowActions();

  document.getElementById('button-refresh-carriers').addEventListener('click', function () {
    var btn = this;
    btn.disabled = true;
    fetch('{{ carriers_refresh }}', { method: 'POST', credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) {
        return r.text().then(function (txt) {
          try { return JSON.parse(txt); }
          catch (e) { throw new Error('Non-JSON response (HTTP ' + r.status + '): ' + txt.substring(0, 200)); }
        });
      })
      .then(function (json) {
        if (json.error) { alert(json.error); return; }
        window.location.reload();
      })
      .catch(function (e) { alert(e.message); })
      .finally(function () { btn.disabled = false; });
  });
})();
</script>
{{ footer }}
